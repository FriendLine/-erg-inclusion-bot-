import discord
import os
from openai import OpenAI
from dotenv import load_dotenv

# Load environment variables
load_dotenv()
DISCORD_TOKEN = os.getenv("DISCORD_TOKEN")
OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")

# The Channel ID extracted from your URL
APPROVAL_CHANNEL_ID = 1495537462829776918

# Set up Discord client
intents = discord.Intents.default()
intents.message_content = True
client = discord.Client(intents=intents)

# Set up OpenAI client
openai_client = OpenAI(api_key=OPENAI_API_KEY)

# Dictionary to store conversation history and drafts per user
user_sessions = {}

# The blended persona instruction
SYSTEM_PROMPT = """You are an expert inclusive language editor for Employee Resource Groups. 
Review the user's text and rewrite it so it is empathetic, highly inclusive, and culturally competent. 
Do not state your perspective, do not explain your edits, and do not introduce yourself. 
Just provide the updated, ready-to-use copy directly. If the user provides feedback on a previous rewrite, apply their edits to the copy."""

@client.event
async def on_ready():
    print(f'Bot is online and logged in as {client.user}')

@client.event
async def on_message(message):
    # Ignore the bot's own messages
    if message.author == client.user:
        return

    # Only respond to Direct Messages
    if not isinstance(message.channel, discord.DMChannel):
        return

    user_id = message.author.id
    user_input = message.content.strip()

    # Initialize a new session for the user if one doesn't exist
    if user_id not in user_sessions:
        user_sessions[user_id] = {
            "history": [{"role": "system", "content": SYSTEM_PROMPT}],
            "latest_draft": ""
        }

    session = user_sessions[user_id]

    # Check if the user is approving the draft
    if user_input.lower() == 'yes' and session["latest_draft"]:
        await message.channel.send("✅ Got it! Sending to the approval channel...")
        
        try:
            # Fetch the specific channel to forward the draft to using your Channel ID
            approval_channel = client.get_channel(APPROVAL_CHANNEL_ID)
            
            if approval_channel:
                # Send the final draft to the channel
                await approval_channel.send(
                    f"**New ERG Content Submission from {message.author.name}**\n\n{session['latest_draft']}"
                )
                await message.channel.send("Draft sent successfully! You can send a new message to start a new review.")
            else:
                await message.channel.send("❌ Error: Could not find the approval channel. Make sure the bot is invited to the server and has permission to view that channel.")
                
            # Clear the session so they can start over
            del user_sessions[user_id]
            
        except Exception as e:
            await message.channel.send(f"❌ There was an error sending the message: {str(e)}")
        return
        
    # If the user says 'no' without providing feedback
    if user_input.lower() == 'no':
        await message.channel.send("Please tell me what you'd like to change or provide your adjusted text, and I'll rewrite it.")
        return

    # Otherwise, treat input as text to be reviewed or feedback on a draft
    session["history"].append({"role": "user", "content": user_input})

    # Show the typing indicator in Discord while waiting for ChatGPT
    async with message.channel.typing():
        try:
            # Call OpenAI API using gpt-4o-mini
            response = openai_client.chat.completions.create(
                model="gpt-4o-mini", 
                messages=session["history"]
            )
            
            ai_reply = response.choices[0].message.content
            
            # Save state
            session["latest_draft"] = ai_reply
            session["history"].append({"role": "assistant", "content": ai_reply})
            
            # Send the rewrite and ask if they are satisfied
            await message.channel.send(ai_reply)
            await message.channel.send("\n**Satisfied?** *(Reply 'yes' to submit for approval, or provide feedback/edits to rewrite again)*")
            
        except Exception as e:
            if "insufficient_quota" in str(e).lower():
                await message.channel.send("❌ Error: OpenAI API out of credits. Please check your billing dashboard.")
            else:
                await message.channel.send(f"❌ Error reaching ChatGPT: {str(e)}")

# Start the bot
client.run(DISCORD_TOKEN)

